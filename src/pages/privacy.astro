---
import Base from '../layouts/Base.astro';
import { LegalPage } from '../components/pages/LegalPage';

const sections = [
  { heading: 'What we collect', body: 'When you email us or send a song request, we receive the details you choose to share - your name, email address and your message. We do not run accounts or store listening history on this website.' },
  { heading: 'How we use it', body: 'We use your details only to respond to your message or play your request on air. We do not sell your data, and we do not share it with third parties for marketing.' },
  { heading: 'Streaming & third parties', body: 'Our live stream is delivered by Citrus3 and we are listed on platforms such as TuneIn, Alexa, Spotify and myTuner. When you listen via those services, their own privacy policies apply.' },
  { heading: 'Your choices', body: 'You can ask us to delete any message you have sent us at any time by emailing info@decadesfm.com.' },
];
---

<Base title="Privacy Notice - Decades Worldwide Radio" description="How Decades Worldwide Radio handles the information you share with us." noindex={true}>
  <LegalPage
    client:load
    title="Privacy Notice"
    intro="Your privacy matters to us. Here's how we handle the information you share when you get in touch."
    sections={sections}
  />
</Base>
