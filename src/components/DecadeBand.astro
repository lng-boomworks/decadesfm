---
import { withBase } from '../utils/url';

// One full-width era band on the /decades page. Reused per decade.
interface Props {
  id: string;        // anchor target, e.g. "80s" → /decades#80s
  title: string;     // "The Eighties"
  blurb: string;     // one evocative sentence about the sound
  artists: string;   // representative artists / flavour
  tint: string;      // CSS color for the glow-card accent
  image: string;     // era photo, e.g. /images/decades/decade-80s.jpg
  flip?: boolean;    // alternate layout side
}
const { id, title, blurb, artists, tint, image, flip = false } = Astro.props;
---
<section id={id} class="scroll-mt-24 py-14 md:py-20 border-b border-night-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class={`flex flex-col md:flex-row items-center gap-8 md:gap-14 ${flip ? "md:flex-row-reverse" : ""}`}>
      <div class="shrink-0 w-full md:w-80">
        <div class="glow-card relative aspect-[3/4] overflow-hidden" style={`--accent: ${tint};`}>
          <img src={withBase(image)} alt={`${title} - era artwork`} class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
      <div class="flex-1">
        <h2 class="mb-4">{title}</h2>
        <p class="text-xl text-cream/90 mb-4 max-w-2xl">{blurb}</p>
        <p class="text-muted text-[15px] uppercase tracking-wider">{artists}</p>
      </div>
    </div>
  </div>
</section>
